{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node",
            "config": {
                "maxLambdaSize": "15mb",
                "includeFiles": "api/**"
            }
        }
    ],
    "routes": [
        {
            "src": "/auth/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/users/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/v1/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.js"
        }
    ]
}
